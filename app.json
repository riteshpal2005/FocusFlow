{
  "expo": {
    "name": "FocusFlow",
    "slug": "focus-flow-app",
    "scheme": "focusflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",

    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.riteshpal.focusflow"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#09090b"
      },
      "package": "dev.riteshpal.focusflow",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#09090b",
          "image": "./assets/splash-icon.png",
          "imageWidth": 250
        }
      ],
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "db673e9f-9eb2-4e4d-89d6-8e3c89b34ae3"
      }
    }
  }
}
